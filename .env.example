APP_ENV=production
DATA_DIR=/data
DATABASE_URL=sqlite:////data/app.db
JOB_WORKER_ENABLED=1
WORKER_POLL_INTERVAL=0.25
WORKER_LEASE_SECONDS=15
WORKER_HEARTBEAT_STALE_SECONDS=5
HOST_PORT=8000

# Optional real providers. Leave blank for the complete deterministic Mock MVP.
ARK_API_KEY=
ARK_IMAGES_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
ARK_PROMPT_MODEL=doubao-seed-2-0-lite-260215
ARK_IDENTITY_QC_ENABLED=true
ARK_IDENTITY_AUTO_PASS_THRESHOLD=0.88
ARK_REQUEST_TIMEOUT_SECONDS=180
ARK_VIDEO_TASKS_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
ARK_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
ARK_VIDEO_POLL_INTERVAL_SECONDS=5
ARK_VIDEO_TIMEOUT_SECONDS=900
# Seedream original URLs are only eligible for this short direct-to-Seedance window.
SEEDREAM_SOURCE_URL_FAST_PATH_SECONDS=600

# Private TOS staging for Seedance source keyframes. Keep the bucket private.
# The short-lived signed URL is used only in worker memory and is never persisted.
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_SECURITY_TOKEN=
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
TOS_BUCKET=
TOS_PRESIGN_TTL_SECONDS=7200
TOS_OBJECT_PREFIX=ai-short-drama/media-staging
TOS_OBJECT_EXPIRES_DAYS=1
TOS_CLEANUP_ON_COMPLETION=1

# Incremental production-workflow rollout. Keep disabled until the matching
# migration, API, UI, and smoke gates are deployed together.
CREATIVE_TEXT_V2=0
BRIEF_TARGETING_V2=0
WORKFLOW_DAG_V1=0
PREPRODUCTION_V2=0
STORYBOARD_ANIMATIC_V2=0
GENERATION_QC_V2=0
AUDIO_PIPELINE_V1=0
MULTITRACK_TIMELINE_V1=0
EXPORT_PROFILES_V2=0
PROVIDER_MEDIA_STAGING_V1=0
